<%- include("../partials/header",{title:"Data Kelas"}) %>

<%- include("../partials/sidebar") %>

<div class="main">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2>Data Kelas</h2>

            <small class="text-muted">

                Manajemen Data Kelas

            </small>

        </div>

        <a href="/kelas/tambah" class="btn btn-primary">

            <i class="bi bi-plus-circle"></i>

            Tambah Kelas

        </a>

    </div>

    <div class="card shadow-sm">

        <div class="card-body">

            <table class="table table-bordered table-hover align-middle">

                <thead class="table-primary">

                    <tr>

                        <th width="60">No</th>

                        <th>Nama Kelas</th>

                        <th>Tingkat</th>

                        <th>Jurusan</th>

                        <th>Wali Kelas</th>

                        <th width="180">Aksi</th>

                    </tr>

                </thead>

                <tbody>

                <% if(kelas.length===0){ %>

                    <tr>

                        <td colspan="6" class="text-center">

                            Belum ada data kelas.

                        </td>

                    </tr>

                <% } %>

                <% kelas.forEach((item,index)=>{ %>

                    <tr>

                        <td><%= index+1 %></td>

                        <td><%= item.nama %></td>

                        <td><%= item.tingkat %></td>

                        <td><%= item.jurusan %></td>

                        <td><%= item.wali_kelas %></td>

                        <td>

                            <a href="/kelas/edit/<%= item.id %>" class="btn btn-warning btn-sm">

                                Edit

                            </a>

                            <a href="/kelas/hapus/<%= item.id %>" class="btn btn-danger btn-sm">

                                Hapus

                            </a>

                        </td>

                    </tr>

                <% }) %>

                </tbody>

            </table>

        </div>

    </div>

</div>

<%- include("../partials/footer") %>