<%- include("../partials/header",{title:"Dashboard Administrator"}) %>

<%- include("../partials/sidebar") %>

<div class="main">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2 class="mb-1">
                Dashboard Administrator
            </h2>

            <p class="text-muted mb-0">
                Selamat datang di SIM-UJIAN SEKOLAH
            </p>

        </div>

        <div>

            <span class="badge bg-primary fs-6">
                CBT v1.0
            </span>

        </div>

    </div>

    <div class="row">

        <!-- GURU -->
        <div class="col-md-3 mb-4">

            <div class="card shadow-sm border-0">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <small class="text-muted">
                                Guru
                            </small>

                            <h2 class="mt-2 text-primary">

                                <%= totalGuru %>

                            </h2>

                        </div>

                        <div class="text-primary fs-1">

                            <i class="bi bi-person-workspace"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- SISWA -->
        <div class="col-md-3 mb-4">

            <div class="card shadow-sm border-0">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <small class="text-muted">
                                Siswa
                            </small>

                            <h2 class="mt-2 text-success">

                                <%= totalSiswa %>

                            </h2>

                        </div>

                        <div class="text-success fs-1">

                            <i class="bi bi-people-fill"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- KELAS -->
        <div class="col-md-3 mb-4">

            <div class="card shadow-sm border-0">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <small class="text-muted">
                                Kelas
                            </small>

                            <h2 class="mt-2 text-warning">

                                <%= totalKelas %>

                            </h2>

                        </div>

                        <div class="text-warning fs-1">

                            <i class="bi bi-building"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- BANK SOAL -->
        <div class="col-md-3 mb-4">

            <div class="card shadow-sm border-0">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>

                            <small class="text-muted">
                                Bank Soal
                            </small>

                            <h2 class="mt-2 text-danger">

                                <%= totalSoal %>

                            </h2>

                        </div>

                        <div class="text-danger fs-1">

                            <i class="bi bi-journal-text"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <div class="card shadow-sm border-0">

        <div class="card-body">

            <h5>
                Selamat Datang
            </h5>

            <p class="text-muted mb-0">

                Dashboard ini menampilkan ringkasan data aplikasi.
                Jumlah Guru sudah dihitung langsung dari database SQLite.
                Selanjutnya kita akan membuat jumlah Siswa, Kelas,
                Mata Pelajaran, dan Bank Soal menjadi dinamis juga.

            </p>

        </div>

    </div>

</div>

<%- include("../partials/footer") %>