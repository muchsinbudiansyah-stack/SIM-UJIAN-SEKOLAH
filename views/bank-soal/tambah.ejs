<%- include("../partials/header",{title:"Tambah Soal"}) %>

<%- include("../partials/sidebar") %>

<div class="main">

<div class="d-flex justify-content-between align-items-center mb-4">

<div>

<h2>

Tambah Soal

</h2>

<small class="text-muted">

Bank Soal SIM-UJIAN SEKOLAH

</small>

</div>

</div>

<div class="card shadow-sm">

<div class="card-body">

<form
    action="/bank-soal/simpan"
    method="POST"
    enctype="multipart/form-data">

<div class="row">

<div class="col-md-6 mb-3">

<label class="form-label">

Mata Pelajaran

</label>

<% if(role==="admin"){ %>
<select
name="mapel_id"
class="form-select"
required>

<option value="">-- Pilih Mata Pelajaran --</option>

<% mapel.forEach(item=>{ %>
<option value="<%= item.id %>"><%= item.nama_mapel %></option>
<% }) %>

</select>
<% }else{ %>

<input
type="text"
class="form-control"
value="<%= mapel[0].nama_mapel %>"
readonly>

<input
type="hidden"
name="mapel_id"
value="<%= mapel[0].id %>">

<% } %>

</div>

<div class="col-md-6 mb-3">

<label class="form-label">Guru</label>

<% if(role==="admin"){ %>

<select
name="guru_id"
class="form-select"
required>

<option value="">-- Pilih Guru --</option>

<% guru.forEach(item=>{ %>
<option value="<%= item.id %>"><%= item.nama %></option>
<% }) %>

</select>

<% }else{ %>

<input
type="text"
class="form-control"
value="<%= guru[0].nama %>"
readonly>

<input
type="hidden"
name="guru_id"
value="<%= guru[0].id %>">

<% } %>

</div>

<div class="col-md-4 mb-3">

<label class="form-label">

Jenis Soal

</label>

<select
id="jenisSoal"
name="jenis"
class="form-select">

<option value="PG">

Pilihan Ganda

</option>

<option value="ESSAY">

Essay

</option>

<option value="BS">

Benar / Salah

</option>

</select>

</div>

<div class="col-md-4 mb-3">

<label>

Bobot Nilai

</label>

<input
type="number"
name="bobot"
value="1"
min="1"
class="form-control">

</div>

<div class="col-md-4 mb-3">

<label>

Status

</label>

<select
name="status"
class="form-select">

<option value="1">

Aktif

</option>

<option value="0">

Nonaktif

</option>

</select>

</div>

<div class="col-md-12 mb-4">

<label>

Pertanyaan

</label>

<textarea
    id="editorSoal"
    name="pertanyaan"
    rows="8"
    class="form-control"></textarea>

</div>

<!-- ================================================= -->
<!-- PILIHAN GANDA -->
<!-- ================================================= -->

<div
id="formPG"
class="row">

<div class="col-md-6 mb-3">

<label>

Pilihan A

</label>

<input
type="text"
name="pilihan_a"
class="form-control">

</div>

<div class="col-md-6 mb-3">

<label>

Pilihan B

</label>

<input
type="text"
name="pilihan_b"
class="form-control">

</div>

<div class="col-md-6 mb-3">

<label>

Pilihan C

</label>

<input
type="text"
name="pilihan_c"
class="form-control">

</div>

<div class="col-md-6 mb-3">

<label>

Pilihan D

</label>

<input
type="text"
name="pilihan_d"
class="form-control">

</div>

<div class="col-md-6 mb-3">

<label>

Pilihan E

</label>

<input
type="text"
name="pilihan_e"
class="form-control">

</div>

<div class="col-md-6 mb-3">

<label>

Jawaban Benar

</label>

<select
name="jawaban"
class="form-select">

<option value="A">A</option>

<option value="B">B</option>

<option value="C">C</option>

<option value="D">D</option>

<option value="E">E</option>

</select>

</div>

</div>

<!-- ============================================== -->
<!-- ESSAY -->
<!-- ============================================== -->

<div
    id="formEssay"
    class="row"
    style="display:none;">

    <div class="col-md-12">

        <div class="alert alert-info">

            <strong>Soal Essay</strong>

            <hr>

            Untuk soal Essay cukup isi pertanyaan.

            Pilihan jawaban tidak diperlukan.

            Penilaian akan dilakukan oleh guru.

        </div>

    </div>

</div>

<!-- ============================================== -->
<!-- BENAR / SALAH -->
<!-- ============================================== -->

<div
    id="formBS"
    class="row"
    style="display:none;">

    <div class="col-md-12 mb-3">

        <label>

            Jawaban Benar

        </label>

        <select
            name="jawaban_bs"
            class="form-select">

            <option value="BENAR">

                Benar

            </option>

            <option value="SALAH">

                Salah

            </option>

        </select>

    </div>

</div>

<!-- ============================================== -->
<!-- MULTIMEDIA SOAL -->
<!-- ============================================== -->

<div class="row">

    <!-- ===================== -->
    <!-- GAMBAR -->
    <!-- ===================== -->

    <div class="col-md-12 mb-4">

        <label class="form-label">

            Gambar Soal (Opsional)

        </label>

        <div id="dropArea" class="drop-area">

            <i class="bi bi-cloud-arrow-up display-5"></i>

            <h5>Drag & Drop Gambar</h5>

            <p class="text-muted">

                atau klik di sini

            </p>

            <input
                type="file"
                id="gambarSoal"
                name="gambar"
                accept=".jpg,.jpeg,.png,.webp,.gif"
                hidden>

        </div>

        <div class="text-center mt-3">

            <img
                id="previewGambar"
                class="img-fluid rounded shadow"
                style="display:none;max-height:250px;">

        </div>

    </div>

    <!-- ===================== -->
    <!-- AUDIO -->
    <!-- ===================== -->

    <div class="col-md-12 mb-4">

        <label class="form-label">

            Audio Soal (Opsional)

        </label>

        <input
            type="file"
            id="audioSoal"
            name="audio"
            class="form-control"
            accept=".mp3,.wav,.ogg,.m4a">

        <div class="mt-3">

            <audio
                id="previewAudio"
                controls
                style="display:none;width:100%;">

                Browser Anda tidak mendukung audio.

            </audio>

        </div>

    </div>

    <!-- ===================== -->
    <!-- VIDEO -->
    <!-- ===================== -->

    <div class="col-md-12 mb-4">

        <label class="form-label">

            Video Soal (Opsional)

        </label>

        <input
            type="file"
            id="videoSoal"
            name="video"
            class="form-control"
            accept=".mp4,.webm,.mov,.avi,.mkv">

        <div class="mt-3">

            <video
                id="previewVideo"
                controls
                style="display:none;width:100%;max-height:400px;">

            </video>

        </div>

    </div>

</div>

<hr>

<div class="d-flex gap-2">

    <button
    type="submit"
    formnovalidate
    class="btn btn-primary">

        <i class="bi bi-save"></i>

        Simpan Soal

    </button>

    <a
        href="/bank-soal"
        class="btn btn-secondary">

        Kembali

    </a>

</div>

</form>

</div>

</div>

</div>

<script src="/assets/tinymce/tinymce.min.js"></script>

<script src="/assets/js/bank-soal.js"></script>

<script>

let editorSoal;

tinymce.init({

    license_key: 'gpl',

    selector: '#editorSoal',

    height: 450,

    menubar: true,

    branding: false,

    promotion: false,

    plugins: [
    'lists',
    'table',
    'link',
    'image',
    'code',
    'fullscreen',
    'preview'
],

automatic_uploads: true,

images_upload_url: '/upload/editor-image',

images_upload_credentials: true,

    toolbar:
'undo redo | blocks | bold italic underline | ' +
'alignleft aligncenter alignright | ' +
'bullist numlist | table | ' +
'image link | ' +
'code preview fullscreen',

    setup: function (editor) {

        editorSoal = editor;

    }

});

// ======================================
// SIMPAN ISI EDITOR KE TEXTAREA
// ======================================

document.querySelector("form").addEventListener("submit", function(e){

    console.log("FORM DIKIRIM");

    tinymce.triggerSave();

});

</script>

<style>

.drop-area{

    border:3px dashed #0d6efd;

    border-radius:12px;

    padding:40px;

    text-align:center;

    cursor:pointer;

    transition:.3s;

    background:#f8f9fa;

}

.drop-area:hover{

    background:#eaf3ff;

}

.drop-area.dragover{

    background:#dcecff;

    border-color:#198754;

}

</style>

<script>

const dropArea=document.getElementById("dropArea");

const input=document.getElementById("gambarSoal");

const preview=document.getElementById("previewGambar");

dropArea.onclick=()=>input.click();

input.onchange=previewImage;

function previewImage(){

    const file=input.files[0];

    if(!file)return;

    if(file.size>2*1024*1024){

        alert("Ukuran gambar maksimal 2 MB");

        input.value="";

        return;

    }

    const reader=new FileReader();

    reader.onload=function(e){

        preview.src=e.target.result;

        preview.style.display="block";

    }

    reader.readAsDataURL(file);

}

dropArea.addEventListener("dragover",(e)=>{

    e.preventDefault();

    dropArea.classList.add("dragover");

});

dropArea.addEventListener("dragleave",()=>{

    dropArea.classList.remove("dragover");

});

dropArea.addEventListener("drop",(e)=>{

    e.preventDefault();

    dropArea.classList.remove("dragover");

    input.files=e.dataTransfer.files;

    previewImage();

});

</script>

// ======================================
// PREVIEW AUDIO
// ======================================

const audioInput =
document.getElementById("audioSoal");

const previewAudio =
document.getElementById("previewAudio");

if(audioInput){

    audioInput.addEventListener("change",function(){

        const file=this.files[0];

        if(!file){

            previewAudio.style.display="none";

            return;

        }

        previewAudio.src=
            URL.createObjectURL(file);

        previewAudio.style.display="block";

    });

}

// ======================================
// PREVIEW VIDEO
// ======================================

const videoInput =
document.getElementById("videoSoal");

const previewVideo =
document.getElementById("previewVideo");

if(videoInput){

    videoInput.addEventListener("change",function(){

        const file=this.files[0];

        if(!file){

            previewVideo.style.display="none";

            return;

        }

        previewVideo.src=
            URL.createObjectURL(file);

        previewVideo.style.display="block";

    });

}

<%- include("../partials/footer") %>