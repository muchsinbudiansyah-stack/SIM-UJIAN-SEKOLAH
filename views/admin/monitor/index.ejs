<!DOCTYPE html>

<html lang="id">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Monitoring Ujian Real-Time</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

<style>

body{

    background:#f4f6f9;

}

.header{

    background:#0d6efd;

    color:white;

    padding:20px;

}

.card-monitor{

    border:none;

    border-radius:15px;

    box-shadow:0 4px 15px rgba(0,0,0,.08);

}

.summary-number{

    font-size:34px;

    font-weight:bold;

}

.progress{

    height:18px;

}

.status{

    font-size:13px;

    padding:6px 12px;

    border-radius:20px;

}

</style>

</head>

<body>

<div class="header">

<div class="container-fluid">

<div class="d-flex justify-content-between align-items-center">

<div>

<h2 class="mb-1">

<i class="bi bi-display"></i>

Monitoring Ujian Real-Time

</h2>

<small>

SIM-UJIAN SEKOLAH

</small>

</div>

<div>

<a href="/admin/dashboard"

class="btn btn-light">

<i class="bi bi-arrow-left"></i>

Dashboard

</a>

</div>

</div>

</div>

</div>

<div class="container-fluid mt-4">

<div class="row">

<!-- TOTAL -->

<div class="col-lg-4 mb-3">

<div class="card card-monitor">

<div class="card-body text-center">

<div class="text-muted">

Total Peserta

</div>

<div

id="totalPeserta"

class="summary-number text-primary">

<%= summary.total %>

</div>

</div>

</div>

</div>

<!-- SEDANG -->

<div class="col-lg-4 mb-3">

<div class="card card-monitor">

<div class="card-body text-center">

<div class="text-muted">

Sedang Ujian

</div>

<div

id="sedangUjian"

class="summary-number text-warning">

<%= summary.sedang %>

</div>

</div>

</div>

</div>

<!-- SELESAI -->

<div class="col-lg-4 mb-3">

<div class="card card-monitor">

<div class="card-body text-center">

<div class="text-muted">

Selesai

</div>

<div

id="selesaiUjian"

class="summary-number text-success">

<%= summary.selesai %>

</div>

</div>

</div>

</div>

</div>

<div class="card card-monitor">

<div class="card-body">

<h4 class="mb-3">

Daftar Peserta

</h4>

<table class="table table-hover align-middle">

<thead class="table-primary">

<tr>

<th>No</th>

<th>Nama</th>

<th>Kelas</th>

<th>Ujian</th>

<th>Status</th>

<th>No</th>

<th>Dijawab</th>

<th>Progress</th>

<th>Aktif Terakhir</th>

</tr>

</thead>

<tbody id="monitorBody">

    <% if(data.length==0){ %>

<tr>

<td colspan="9" class="text-center text-muted">

Belum ada peserta yang mengikuti ujian.

</td>

</tr>

<% } %>

<% data.forEach((m,i)=>{ %>

<tr>

<td>

<%= i+1 %>

</td>

<td>

<strong>

<%= m.nama %>

</strong>

<br>

<small class="text-muted">

<%= m.nisn %>

</small>

</td>

<td>

<%= m.kelas %>

</td>

<td>

<%= m.nama_ujian %>

</td>

<td>

<% if(m.status=="Sedang Ujian"){ %>

<span class="badge bg-warning text-dark">

Sedang Ujian

</span>

<% }else if(m.status=="Selesai"){ %>

<span class="badge bg-success">

Selesai

</span>

<% }else{ %>

<span class="badge bg-danger">

Belum Mulai

</span>

<% } %>

</td>

<td>

<%= m.nomor_terakhir %>

</td>

<td>

<%= m.jumlah_dijawab %>

</td>

<td style="width:180px;">

<div class="progress">

<div

class="progress-bar"

role="progressbar"

style="width:<%= Math.min((m.jumlah_dijawab/20)*100,100) %>%">

<%= m.jumlah_dijawab %>

</div>

</div>

</td>

<td>

<small>

<%= m.last_activity || "-" %>

</small>

</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

</div>

</div>

<script>

async function loadRealtime(){

    try{

        const response=await fetch(

            "/monitor/realtime"

        );

        const hasil=await response.json();

        if(!hasil.success){

            return;

        }

        document.getElementById(

            "totalPeserta"

        ).innerHTML=hasil.summary.total;

        document.getElementById(

            "sedangUjian"

        ).innerHTML=hasil.summary.sedang;

        document.getElementById(

            "selesaiUjian"

        ).innerHTML=hasil.summary.selesai;

        let html="";

        hasil.data.forEach((m,index)=>{

            let badge="";

            if(m.status=="Sedang Ujian"){

                badge=`<span class="badge bg-warning text-dark">Sedang Ujian</span>`;

            }else if(m.status=="Selesai"){

                badge=`<span class="badge bg-success">Selesai</span>`;

            }else{

                badge=`<span class="badge bg-danger">Belum Mulai</span>`;

            }

            let persen=Math.min(

                (m.jumlah_dijawab / m.jumlah_soal) * 100,

                100

            );

                        html += `

            <tr>

                <td>${index+1}</td>

                <td>

                    <strong>${m.nama}</strong><br>

                    <small class="text-muted">

                        ${m.nisn ?? "-"}

                    </small>

                </td>

                <td>${m.kelas}</td>

                <td>${m.nama_ujian}</td>

                <td>${badge}</td>

                <td>${m.nomor_terakhir}</td>

                <td>${m.jumlah_dijawab}</td>

                <td style="width:180px;">

                    <div class="progress">

                        <div

                            class="progress-bar"

                            role="progressbar"

                            style="width:${persen}%">

                            ${m.jumlah_dijawab}

                        </div>

                    </div>

                </td>

                <td>

                    <small>

                        ${m.last_activity ?? "-"}

                    </small>

                </td>

            </tr>

            `;

        });

        if(hasil.data.length===0){

            html = `

            <tr>

                <td colspan="9"

                    class="text-center text-muted">

                    Belum ada peserta yang mengikuti ujian.

                </td>

            </tr>

            `;

        }

        document.getElementById(

            "monitorBody"

        ).innerHTML = html;

    }

    catch(err){

        console.log(err);

    }

}

// ======================================
// AUTO REFRESH
// ======================================

setInterval(

    loadRealtime,

    5000

);

// Jalankan sekali saat halaman dibuka
loadRealtime();

</script>

</body>

</html>