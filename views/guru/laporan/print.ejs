<!DOCTYPE html>
<html lang="id">

<head>

<meta charset="UTF-8">

<title>Laporan Nilai Ujian</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{

    font-family:Arial,Helvetica,sans-serif;
    margin:35px;
    color:#000;
    font-size:13px;

}

.header{

    display:flex;
    align-items:center;
    border-bottom:3px solid #000;
    padding-bottom:15px;
    margin-bottom:20px;

}

.logo{

    width:90px;
    margin-right:20px;

}

.judul{

    flex:1;
    text-align:center;

}

.judul h2{

    margin:0;
    font-weight:bold;

}

.judul h4{

    margin:3px 0;

}

.judul p{

    margin:0;

}

.info{

    margin-top:15px;
    margin-bottom:20px;

}

.info table{

    width:100%;

}

.info td{

    padding:3px;

}

table.nilai{

    width:100%;
    border-collapse:collapse;
    margin-top:15px;

}

table.nilai th{

    background:#e9ecef;
    border:1px solid #000;
    padding:8px;
    text-align:center;

}

table.nilai td{

    border:1px solid #000;
    padding:7px;

}

.text-center{

    text-align:center;

}

.statistik{

    margin-top:25px;
    width:350px;

}

.statistik td{

    padding:5px;

}

.ttd{

    margin-top:80px;
    width:100%;

}

.ttd-kanan{

    width:300px;
    float:right;
    text-align:center;

}

.nama-guru{

    margin-top:80px;
    font-weight:bold;
    text-decoration:underline;

}

</style>

</head>

<body>

<div class="header">

<img
src="/assets/img/logo.png"
class="logo">

<div class="judul">

<h2>

PEMERINTAH KABUPATEN INDRAGIRI HILIR

</h2>

<h4>

SMA NEGERI 1 TELUK BELENGKONG

</h4>

<p>

Jl. Pendidikan No.02 Beringin Mulya

</p>

<p>

Kecamatan Teluk Belengkong

</p>

</div>

</div>

<h3 class="text-center">

LAPORAN HASIL UJIAN

</h3>

<div class="info">

<table>

<tr>

<td width="180">

Nama Ujian

</td>

<td width="20">

:

</td>

<td>

<%= ujian.nama_ujian %>

</td>

</tr>

<tr>

<td>

Mata Pelajaran

</td>

<td>

:

</td>

<td>

<%= ujian.nama_mapel %>

</td>

</tr>

<tr>

<td>

Guru

</td>

<td>

:

</td>

<td>

<%= ujian.nama_guru %>

</td>

</tr>

<tr>

<td>

Tanggal Cetak

</td>

<td>

:

</td>

<td>

<%= new Date().toLocaleDateString("id-ID") %>

</td>

</tr>

</table>

</div>

<table class="nilai">

<thead>

<tr>

<th>No</th>

<th>NISN</th>

<th>Nama Siswa</th>

<th>Kelas</th>

<th>Nilai</th>

<th>Benar</th>

<th>Salah</th>

<th>Kosong</th>

<th>Status</th>

</tr>

</thead>

<tbody>

<%

let no=1;

let total=0;

let tertinggi=0;

let terendah=100;

hasil.forEach(item=>{

total+=Number(item.nilai);

if(item.nilai>tertinggi) tertinggi=item.nilai;
if(item.nilai<terendah) terendah=item.nilai;

%>

<tr>

<td class="text-center">

<%= no++ %>

</td>

<td>

<%= item.nisn %>

</td>

<td>

<%= item.nama %>

</td>

<td>

<%= item.kelas %>

</td>

<td class="text-center">

<%= item.nilai %>

</td>

<td class="text-center">

<%= item.benar %>

</td>

<td class="text-center">

<%= item.salah %>

</td>

<td class="text-center">

<%= item.kosong %>

</td>

<td class="text-center">

<%= item.status %>

</td>

</tr>

<%

})

%>

</tbody>

</table>

<table class="statistik">

<tr>

<td>

Jumlah Peserta

</td>

<td>

:

</td>

<td>

<%= hasil.length %>

</td>

</tr>

<tr>

<td>

Nilai Rata-rata

</td>

<td>

:

</td>

<td>

<%= hasil.length?(total/hasil.length).toFixed(2):0 %>

</td>

</tr>

<tr>

<td>

Nilai Tertinggi

</td>

<td>

:

</td>

<td>

<%= tertinggi %>

</td>

</tr>

<tr>

<td>

Nilai Terendah

</td>

<td>

:

</td>

<td>

<%= hasil.length?terendah:0 %>

</td>

</tr>

</table>

<div class="ttd">

<div class="ttd-kanan">

<p>

Teluk Belengkong,

<%= new Date().toLocaleDateString("id-ID") %>

</p>

<p>

Guru Mata Pelajaran

</p>

<div class="nama-guru">

<%= ujian.nama_guru %>

</div>

</div>

</div>

</body>

</html>