<%- include("../../partials/header",{title:"Hasil Ujian"}) %>

<%- include("../../partials/sidebar") %>

<div class="main">

<div class="row mb-4">

    <div class="col-md-8">

        <h2 class="fw-bold">

            <i class="bi bi-bar-chart-fill"></i>

            Hasil Ujian

        </h2>

        <p class="text-muted">

            Daftar hasil ujian siswa

        </p>

    </div>

</div>

<div class="card shadow-sm">

<div class="card-body">

<div class="table-responsive">

<table
id="tabelHasil"
class="table table-striped table-hover align-middle">

<thead class="table-primary">

<tr>

<th width="60">No</th>

<th>Nama Siswa</th>

<th>NISN</th>

<th>Kelas</th>

<th>Mata Pelajaran</th>

<th width="90">Nilai</th>

<th width="80">Benar</th>

<th width="80">Salah</th>

<th width="80">Kosong</th>

<th width="110">Status</th>

<th width="120">Aksi</th>

</tr>

</thead>

<tbody>

<%

let no = 1;

hasil.forEach(item=>{

%>

<tr>

<td>

<%= no++ %>

</td>

<td>

<%= item.nama_siswa %>

</td>

<td>

<%= item.nisn %>

</td>

<td>

<%= item.nama_kelas %>

</td>

<td>

<%= item.nama_mapel %>

</td>

<td>

<span class="badge bg-success">

<%= item.nilai %>

</span>

</td>

<td>

<%= item.benar %>

</td>

<td>

<%= item.salah %>

</td>

<td>

<%= item.kosong %>

</td>

<td>

<span class="badge bg-primary">

<%= item.status %>

</span>

</td>

<td>

<a
href="/hasil/detail/<%= item.id %>"
class="btn btn-info btn-sm">

<i class="bi bi-eye"></i>

</a>

</td>

</tr>

<%

})

%>

</tbody>

</table>

</div>

</div>

</div>

</div>

<script>

$(function(){

$("#tabelHasil").DataTable({

pageLength:10,

language:{

search:"Cari :",

lengthMenu:"Tampilkan _MENU_ data",

zeroRecords:"Data tidak ditemukan",

info:"Menampilkan _START_ - _END_ dari _TOTAL_ data",

paginate:{

previous:"←",

next:"→"

}

}

});

});

</script>

<%- include("../../partials/footer") %>