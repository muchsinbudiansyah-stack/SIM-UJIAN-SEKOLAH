<%- include("../../partials/header",{title:"Dashboard Guru"}) %>

<%- include("../../partials/sidebar") %>

<div class="main">

<div class="container-fluid">

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>

        <h2 class="fw-bold">

            Dashboard Guru

        </h2>

        <div class="text-muted">

            Selamat datang,

            <strong>

                <%= guru.nama %>

            </strong>

        </div>

    </div>

</div>

<!-- ============================ -->
<!-- STATISTIK -->
<!-- ============================ -->

<div class="row">

<div class="col-md-3">

<div class="card shadow-sm border-0">

<div class="card-body text-center">

<h6 class="text-muted">

Bank Soal

</h6>

<h2 class="fw-bold text-primary">

<%= statistik.bankSoal %>

</h2>

</div>

</div>

</div>

<div class="col-md-3">

<div class="card shadow-sm border-0">

<div class="card-body text-center">

<h6 class="text-muted">

Ujian

</h6>

<h2 class="fw-bold text-success">

<%= statistik.ujian %>

</h2>

</div>

</div>

</div>

<div class="col-md-3">

<div class="card shadow-sm border-0">

<div class="card-body text-center">

<h6 class="text-muted">

Sedang Ujian

</h6>

<h2 class="fw-bold text-warning">

<%= statistik.sedang %>

</h2>

</div>

</div>

</div>

<div class="col-md-3">

<div class="card shadow-sm border-0">

<div class="card-body text-center">

<h6 class="text-muted">

Selesai

</h6>

<h2 class="fw-bold text-danger">

<%= statistik.selesai %>

</h2>

</div>

</div>

</div>

</div>

<!-- ============================ -->
<!-- AKTIVITAS -->
<!-- ============================ -->

<div class="card shadow-sm mt-4">

<div class="card-header bg-primary text-white">

Aktivitas Terbaru

</div>

<div class="card-body p-0">

<table class="table table-hover mb-0">

<thead>

<tr>

<th>Nama Ujian</th>

<th>Status</th>

<th>Mulai</th>

<th>Selesai</th>

</tr>

</thead>

<tbody>

<% if(aktivitas.length===0){ %>

<tr>

<td colspan="4" class="text-center">

Belum ada aktivitas.

</td>

</tr>

<% } %>

<% aktivitas.forEach(item=>{ %>

<tr>

<td>

<%= item.nama_ujian %>

</td>

<td>

<% if(item.status==="Sedang Ujian"){ %>

<span class="badge bg-warning">

Sedang Ujian

</span>

<% }else{ %>

<span class="badge bg-success">

Selesai

</span>

<% } %>

</td>

<td>

<%= item.waktu_mulai || "-" %>

</td>

<td>

<%= item.waktu_selesai || "-" %>

</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

</div>

</div>

</div>

<%- include("../../partials/footer") %>