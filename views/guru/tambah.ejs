<%- include("../partials/header",{title:"Tambah Guru"}) %>

<%- include("../partials/sidebar") %>

<div class="main">

    <div class="container-fluid">

        <div class="card shadow">

            <div class="card-header bg-success text-white">

                <h4 class="mb-0">

                    <i class="bi bi-person-plus-fill"></i>

                    Tambah Data Guru

                </h4>

            </div>

            <div class="card-body">

                <form action="/guru/simpan" method="POST">

                    <div class="row">

                        <div class="col-md-6 mb-3">

                            <label class="form-label">

                                NIP

                            </label>

                            <input
                                type="text"
                                name="nip"
                                class="form-control"
                                required>

                        </div>

                        <div class="col-md-6 mb-3">

                            <label class="form-label">

                                Nama Guru

                            </label>

                            <input
                                type="text"
                                name="nama"
                                class="form-control"
                                required>

                        </div>

                        <div class="col-md-6 mb-3">

                            <label class="form-label">

                                Email

                            </label>

                            <input
                                type="email"
                                name="email"
                                class="form-control">

                        </div>

                        <div class="col-md-6 mb-3">

                            <label class="form-label">

                                No HP

                            </label>

                            <input
                                type="text"
                                name="hp"
                                class="form-control">

                        </div>

                    </div>

                    <hr>

                    <h5 class="mb-3">

                        Mata Pelajaran yang Diampu

                    </h5>

                    <div class="row">

                        <% mapel.forEach(function(item){ %>

                            <div class="col-lg-4 col-md-6 mb-2">

                                <div class="form-check">

                                    <input

                                        class="form-check-input"

                                        type="checkbox"

                                        name="mapel"

                                        value="<%= item.id %>"

                                        id="mapel<%= item.id %>"

                                    >

                                    <label

                                        class="form-check-label"

                                        for="mapel<%= item.id %>">

                                        <strong>

                                            <%= item.nama_mapel %>

                                        </strong>

                                    </label>

                                </div>

                            </div>

                        <% }) %>

                    </div>

                    <hr>

                    <button
                        type="submit"
                        class="btn btn-success">

                        <i class="bi bi-save"></i>

                        Simpan Guru

                    </button>

                    <a
                        href="/guru"
                        class="btn btn-secondary">

                        Kembali

                    </a>

                </form>

            </div>

        </div>

    </div>

</div>

<%- include("../partials/footer") %>