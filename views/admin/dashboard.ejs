<%- include("../partials/header",{title:"Dashboard Administrator"}) %>

<%- include("../partials/sidebar") %>

<div class="main">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2 class="mb-1">

                Dashboard Administrator

            </h2>

            <p class="text-muted mb-0">

                Selamat datang di SIM-UJIAN SEKOLAH

            </p>

        </div>

        <span class="badge bg-primary fs-6">

            CBT v1.0

        </span>

    </div>

    <div class="row">

        <!-- GURU -->
        <div class="col-md-3 mb-4">

            <div class="card shadow-sm border-0">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <small class="text-muted">

                                Guru

                            </small>

                            <h2 class="text-primary mt-2">

                                <%= totalGuru %>

                            </h2>

                        </div>

                        <div class="text-primary fs-1">

                            <i class="bi bi-person-workspace"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- SISWA -->
        <div class="col-md-3 mb-4">

            <div class="card shadow-sm border-0">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <small class="text-muted">

                                Siswa

                            </small>

                            <h2 class="text-success mt-2">

                                <%= totalSiswa %>

                            </h2>

                        </div>

                        <div class="text-success fs-1">

                            <i class="bi bi-people-fill"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- KELAS -->
        <div class="col-md-3 mb-4">

            <div class="card shadow-sm border-0">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <small class="text-muted">

                                Kelas

                            </small>

                            <h2 class="text-warning mt-2">

                                <%= totalKelas %>

                            </h2>

                        </div>

                        <div class="text-warning fs-1">

                            <i class="bi bi-building"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- MAPEL -->
        <div class="col-md-3 mb-4">

            <div class="card shadow-sm border-0">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <small class="text-muted">

                                Mata Pelajaran

                            </small>

                            <h2 class="text-danger mt-2">

                                <%= totalMapel %>

                            </h2>

                        </div>

                        <div class="text-danger fs-1">

                            <i class="bi bi-book-half"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <div class="card shadow-sm border-0">

        <div class="card-body">

            <h5>

                Informasi Sistem

            </h5>

            <p class="text-muted mb-0">

                Dashboard sekarang sudah mengambil jumlah Guru, Kelas, dan Mata Pelajaran langsung dari database SQLite.

                Selanjutnya kita akan menghubungkan jumlah Siswa, Bank Soal, Ujian, dan Hasil secara otomatis.

            </p>

        </div>

    </div>

</div>

<%- include("../partials/footer") %>