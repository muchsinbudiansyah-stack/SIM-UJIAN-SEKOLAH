<!DOCTYPE html>
<html lang="id">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1">

<title>Dashboard Peserta</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{

    background:#eef2f7;

}

.header{

    background:#0d6efd;

    color:white;

    padding:20px;

    border-radius:12px;

    margin-bottom:25px;

}

.card-ujian{

    border:none;

    border-radius:15px;

    box-shadow:0 8px 20px rgba(0,0,0,.08);

    transition:.3s;

}

.card-ujian:hover{

    transform:translateY(-3px);

}

.badge-status{

    font-size:14px;

}

.info{

    font-size:15px;

    margin-bottom:5px;

}

</style>

</head>

<body>

<div class="container mt-4">

<div class="header">

<h2>SIM UJIAN SEKOLAH</h2>

<p class="mb-1">

Selamat datang,

<b><%= siswa.nama %></b>

</p>

<p class="mb-0">

Kelas ID :

<b><%= siswa.kelas_id %></b>

</p>

</div>

<h4 class="mb-4">

Daftar Ujian

</h4>

<div class="row">

<% if(ujian.length==0){ %>

<div class="col-md-12">

<div class="alert alert-warning">

Belum ada ujian yang tersedia.

</div>

</div>

<% } %>

<% ujian.forEach(item=>{ %>

<div class="col-md-6 mb-4">

<div class="card card-ujian">

<div class="card-body">

<h4>

<%= item.nama_ujian %>

</h4>

<hr>

<p class="info">

<b>Mata Pelajaran :</b>

<%= item.nama_mapel %>

</p>

<p class="info">

<b>Tanggal :</b>

<%= item.tanggal %>

</p>

<p class="info">

<b>Jam :</b>

<%= item.jam_mulai %>

</p>

<p class="info">

<b>Durasi :</b>

<%= item.durasi %> Menit

</p>

<p class="info">

<b>Jumlah Soal :</b>

<%= item.jumlah_soal %>

</p>

<div class="d-grid mt-4">

<a

href="/peserta/ujian/<%= item.id %>"

class="btn btn-primary btn-lg">

Mulai Ujian

</a>

</div>

</div>

</div>

</div>

<% }) %>

</div>

<div class="mt-4">

<a

href="/peserta/logout"

class="btn btn-danger">

Logout

</a>

</div>

</div>

</body>

</html>