<%- include("../partials/header",{title:"Buat Ujian"}) %>

<%- include("../partials/sidebar") %>

<div class="main">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2>Buat Ujian</h2>

            <small class="text-muted">

                Konfigurasi ujian CBT

            </small>

        </div>

    </div>

    <div class="card shadow-sm">

        <div class="card-body">

            <form action="/ujian/simpan" method="POST">

                <div class="row">

                    <div class="col-md-6 mb-3">

                        <label class="form-label">
                            Nama Ujian
                        </label>

                        <input
                            type="text"
                            name="nama_ujian"
                            class="form-control"
                            placeholder="Contoh : PTS Semester Ganjil"
                            required>

                    </div>

                    <div class="col-md-6 mb-3">

                        <label class="form-label">
                            Mata Pelajaran
                        </label>

                        <select
                            name="mapel_id"
                            class="form-select"
                            required>

                            <option value="">-- Pilih Mata Pelajaran --</option>

                            <% mapel.forEach(item=>{ %>

                                <option value="<%= item.id %>">

                                    <%= item.nama_mapel %>

                                </option>

                            <% }) %>

                        </select>

                    </div>

                    <div class="col-md-6 mb-3">

                        <label class="form-label">
                            Kelas
                        </label>

                        <select
                            name="kelas_id"
                            class="form-select"
                            required>

                            <option value="">-- Pilih Kelas --</option>

                            <% kelas.forEach(item=>{ %>

                                <option value="<%= item.id %>">

                                    <%= item.nama %>

                                </option>

                            <% }) %>

                        </select>

                    </div>

                    <div class="col-md-6 mb-3">

                        <label class="form-label">
                            Guru
                        </label>

                        <select
                            name="guru_id"
                            class="form-select"
                            required>

                            <option value="">-- Pilih Guru --</option>

                            <% guru.forEach(item=>{ %>

                                <option value="<%= item.id %>">

                                    <%= item.nama %>

                                </option>

                            <% }) %>

                        </select>

                    </div>

                    <div class="col-md-4 mb-3">

                        <label class="form-label">
                            Tanggal
                        </label>

                        <input
                            type="date"
                            name="tanggal"
                            class="form-control"
                            required>

                    </div>

                    <div class="col-md-4 mb-3">

                        <label class="form-label">
                            Jam Mulai
                        </label>

                        <input
                            type="time"
                            name="jam_mulai"
                            class="form-control"
                            required>

                    </div>

                    <div class="col-md-4 mb-3">

                        <label class="form-label">
                            Jam Selesai
                        </label>

                        <input
                            type="time"
                            name="jam_selesai"
                            class="form-control"
                            required>

                    </div>

                    <div class="col-md-4 mb-3">

                        <label class="form-label">
                            Durasi (Menit)
                        </label>

                        <input
                            type="number"
                            name="durasi"
                            class="form-control"
                            value="60"
                            min="1"
                            required>

                    </div>

                    <div class="col-md-4 mb-3">

                        <label class="form-label">
                            Jumlah Soal
                        </label>

                        <input
                            type="number"
                            name="jumlah_soal"
                            class="form-control"
                            value="20"
                            min="1"
                            required>

                    </div>

                    <div class="col-md-4 mb-3">

                        <label class="form-label">
                            Token Ujian
                        </label>

                        <input
                            type="text"
                            name="token"
                            class="form-control"
                            placeholder="Contoh : ABC123">

                    </div>

                    <div class="col-md-6 mb-3">

                        <div class="form-check">

                            <input
                                class="form-check-input"
                                type="checkbox"
                                name="acak_soal"
                                value="1"
                                checked>

                            <label class="form-check-label">

                                Acak Soal

                            </label>

                        </div>

                    </div>

                    <div class="col-md-6 mb-3">

                        <div class="form-check">

                            <input
                                class="form-check-input"
                                type="checkbox"
                                name="acak_jawaban"
                                value="1"
                                checked>

                            <label class="form-check-label">

                                Acak Jawaban

                            </label>

                        </div>

                    </div>

                </div>

                <hr>

                <button
                    type="submit"
                    class="btn btn-primary">

                    <i class="bi bi-save"></i>

                    Simpan Ujian

                </button>

                <a
                    href="/ujian"
                    class="btn btn-secondary">

                    Kembali

                </a>

            </form>

        </div>

    </div>

</div>

<%- include("../partials/footer") %>