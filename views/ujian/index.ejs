<%- include("../partials/header",{title:"Data Ujian"}) %>

<%- include("../partials/sidebar") %>

<div class="main">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2>Data Ujian</h2>

            <small class="text-muted">
                Manajemen Jadwal Ujian CBT
            </small>

        </div>

        <a href="/ujian/tambah" class="btn btn-primary">

            <i class="bi bi-plus-circle"></i>

            Buat Ujian

        </a>

    </div>

    <div class="card shadow-sm">

        <div class="card-body">

            <table class="table table-bordered table-hover align-middle">

                <thead class="table-primary">

                    <tr>

                        <th width="60">No</th>
                        <th>Nama Ujian</th>
                        <th>Mata Pelajaran</th>
                        <th>Kelas</th>
                        <th>Guru</th>
                        <th>Durasi</th>
                        <th>Status</th>
                        <th width="200">Aksi</th>

                    </tr>

                </thead>

                <tbody>

                <% if(ujian.length===0){ %>

                    <tr>

                        <td colspan="8" class="text-center">

                            Belum ada data ujian.

                        </td>

                    </tr>

                <% } %>

                <% ujian.forEach((item,index)=>{ %>

                    <tr>

                        <td><%= index+1 %></td>

                        <td><%= item.nama_ujian %></td>

                        <td><%= item.nama_mapel %></td>

                        <td><%= item.nama_kelas %></td>

                        <td><%= item.nama_guru %></td>

                        <td><%= item.durasi %> Menit</td>

                        <td>

                            <% if(item.status==1){ %>

                                <span class="badge bg-success">

                                    Aktif

                                </span>

                            <% } else { %>

                                <span class="badge bg-secondary">

                                    Nonaktif

                                </span>

                            <% } %>

                        </td>

                        <td>

                            <a
                                href="/ujian/edit/<%= item.id %>"
                                class="btn btn-warning btn-sm">

                                <i class="bi bi-pencil-square"></i>

                                Edit

                            </a>

                            <a
                                href="/ujian/hapus/<%= item.id %>"
                                class="btn btn-danger btn-sm"
                                onclick="return confirm('Yakin ingin menghapus ujian ini?')">

                                <i class="bi bi-trash"></i>

                                Hapus

                            </a>

                        </td>

                    </tr>

                <% }) %>

                </tbody>

            </table>

        </div>

    </div>

</div>

<%- include("../partials/footer") %>