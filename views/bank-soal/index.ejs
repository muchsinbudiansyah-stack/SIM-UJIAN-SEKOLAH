<%- include("../partials/header",{title:"Bank Soal"}) %>

<%- include("../partials/sidebar") %>

<div class="main">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2>Bank Soal</h2>

            <small class="text-muted">

                Kelola seluruh soal ujian sekolah

            </small>

        </div>

        <div>

            <a
                href="/bank-soal/tambah"
                class="btn btn-primary">

                <i class="bi bi-plus-circle"></i>

                Tambah Soal

            </a>

            <a
                href="/bank-soal/import-word"
                class="btn btn-success">

                <i class="bi bi-file-earmark-word"></i>

                Import Word

            </a>

            <button
                class="btn btn-secondary"
                disabled>

                <i class="bi bi-file-earmark-excel"></i>

                Import Excel

            </button>

        </div>

    </div>

    <!-- Grid Folder Mata Pelajaran -->
    <div class="row">
        <% if(typeof mapel !== 'undefined' && mapel.length > 0) { %>
            <% mapel.forEach((item, index) => { %>
                <div class="col-md-3 mb-4">
                    <div class="card h-100 shadow-sm border-0 folder-card bg-white">
                        <div class="card-body text-center p-4">
                            <!-- Icon Folder -->
                            <i class="bi bi-folder-fill text-warning" style="font-size: 4rem;"></i>
                            <h5 class="card-title mt-3 text-dark fw-bold"><%= item.nama_mapel %></h5>
                            <!-- Link yang membungkus seluruh area card -->
                            <a href="/bank-soal/mapel/<%= item.id %>" class="stretched-link"></a>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-12">
                <div class="alert alert-secondary text-center">
                    <i class="bi bi-info-circle me-2"></i> Belum ada data Mata Pelajaran.
                </div>
            </div>
        <% } %>
    </div>

    <!-- CSS tambahan untuk efek folder -->
    <style>
        .folder-card {
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            cursor: pointer;
            border-radius: 12px;
        }
        .folder-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
            background-color: #f8f9fa !important;
        }
    </style>

<%- include("../partials/footer") %>