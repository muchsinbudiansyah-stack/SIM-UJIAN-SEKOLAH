<%- include("../partials/header",{title:"Dashboard Administrator"}) %>

<%- include("../partials/sidebar") %>

<div class="main">

    <!-- ===================================== -->
    <!-- HEADER -->
    <!-- ===================================== -->

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2 class="fw-bold mb-1">

                Dashboard Administrator

            </h2>

            <p class="text-muted mb-0">

                Selamat Datang di SIM-UJIAN SEKOLAH

            </p>

        </div>

        <span class="badge bg-primary fs-6">

            CBT v2.0

        </span>

    </div>

    <!-- ===================================== -->
    <!-- ROW 1 -->
    <!-- ===================================== -->

    <div class="row g-4">

        <!-- GURU -->

        <div class="col-lg-3 col-md-6">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-body d-flex justify-content-between align-items-center">

                    <div>

                        <small class="text-muted">

                            Guru

                        </small>

                        <h2 class="text-primary mt-2">

                            <%= statistik.guru %>

                        </h2>

                    </div>

                    <i class="bi bi-person-workspace fs-1 text-primary"></i>

                </div>

            </div>

        </div>

        <!-- SISWA -->

        <div class="col-lg-3 col-md-6">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-body d-flex justify-content-between align-items-center">

                    <div>

                        <small class="text-muted">

                            Siswa

                        </small>

                        <h2 class="text-success mt-2">

                            <%= statistik.siswa %>

                        </h2>

                    </div>

                    <i class="bi bi-people-fill fs-1 text-success"></i>

                </div>

            </div>

        </div>

        <!-- KELAS -->

        <div class="col-lg-3 col-md-6">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-body d-flex justify-content-between align-items-center">

                    <div>

                        <small class="text-muted">

                            Kelas

                        </small>

                        <h2 class="text-warning mt-2">

                            <%= statistik.kelas %>

                        </h2>

                    </div>

                    <i class="bi bi-building fs-1 text-warning"></i>

                </div>

            </div>

        </div>

        <!-- MAPEL -->

        <div class="col-lg-3 col-md-6">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-body d-flex justify-content-between align-items-center">

                    <div>

                        <small class="text-muted">

                            Mata Pelajaran

                        </small>

                        <h2 class="text-danger mt-2">

                            <%= statistik.mapel %>

                        </h2>

                    </div>

                    <i class="bi bi-book-half fs-1 text-danger"></i>

                </div>

            </div>

        </div>

    </div>

    <!-- ===================================== -->
    <!-- ROW 2 -->
    <!-- ===================================== -->

    <div class="row g-4 mt-1">

                <!-- UJIAN -->

        <div class="col-lg-3 col-md-6">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-body d-flex justify-content-between align-items-center">

                    <div>

                        <small class="text-muted">

                            Ujian

                        </small>

                        <h2 class="text-info mt-2">

                            <%= statistik.ujian %>

                        </h2>

                    </div>

                    <i class="bi bi-file-earmark-text fs-1 text-info"></i>

                </div>

            </div>

        </div>

        <!-- BANK SOAL -->

        <div class="col-lg-3 col-md-6">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-body d-flex justify-content-between align-items-center">

                    <div>

                        <small class="text-muted">

                            Bank Soal

                        </small>

                        <h2 class="text-primary mt-2">

                            <%= statistik.bankSoal %>

                        </h2>

                    </div>

                    <i class="bi bi-journal-text fs-1 text-primary"></i>

                </div>

            </div>

        </div>

        <!-- SEDANG UJIAN -->

        <div class="col-lg-3 col-md-6">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-body d-flex justify-content-between align-items-center">

                    <div>

                        <small class="text-muted">

                            Sedang Ujian

                        </small>

                        <h2 class="text-warning mt-2">

                            <%= statistik.sedang %>

                        </h2>

                    </div>

                    <i class="bi bi-clock-history fs-1 text-warning"></i>

                </div>

            </div>

        </div>

        <!-- SELESAI -->

        <div class="col-lg-3 col-md-6">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-body d-flex justify-content-between align-items-center">

                    <div>

                        <small class="text-muted">

                            Selesai

                        </small>

                        <h2 class="text-success mt-2">

                            <%= statistik.selesai %>

                        </h2>

                    </div>

                    <i class="bi bi-check-circle fs-1 text-success"></i>

                </div>

            </div>

        </div>

    </div>

    <!-- ===================================== -->
    <!-- GRAFIK -->
    <!-- ===================================== -->

    <div class="card shadow-sm border-0 mt-4">

        <div class="card-body">

            <h5 class="mb-4">

                Statistik SIM-UJIAN SEKOLAH

            </h5>

            <div style="height:350px;">

    <canvas id="dashboardChart"></canvas>

</div>

    </div>

    <!-- ===================================== -->
    <!-- AKTIVITAS TERBARU -->
    <!-- ===================================== -->

    <div class="card shadow-sm border-0 mt-4">

        <div class="card-body">

            <h5 class="mb-3">

                Aktivitas Terbaru

            </h5>

            <table class="table table-hover">

                <thead>

                    <tr>

                        <th>Ujian</th>

                        <th>Status</th>

                        <th>Mulai</th>

                        <th>Selesai</th>

                    </tr>

                </thead>

                <tbody>

                <% if(aktivitas && aktivitas.length>0){ %>

                    <% aktivitas.forEach(item=>{ %>

                    <tr>

                        <td><%= item.nama_ujian %></td>

                        <td><%= item.status %></td>

                        <td><%= item.waktu_mulai || "-" %></td>

                        <td><%= item.waktu_selesai || "-" %></td>

                    </tr>

                    <% }) %>

                <% } else { %>

                    <tr>

                        <td colspan="4" class="text-center text-muted">

                            Belum ada aktivitas.

                        </td>

                    </tr>

                <% } %>

                </tbody>

            </table>

        </div>

    </div>

        <!-- ===================================== -->
    <!-- INFORMASI SISTEM -->
    <!-- ===================================== -->

    <div class="card shadow-sm border-0 mt-4">

        <div class="card-body">

            <h5>

                Informasi Sistem

            </h5>

            <p class="text-muted mb-0">

                Dashboard Administrator SIM-UJIAN SEKOLAH menampilkan statistik data
                secara langsung dari database. Informasi ini meliputi jumlah Guru,
                Siswa, Kelas, Mata Pelajaran, Bank Soal, Ujian, peserta yang sedang
                mengerjakan ujian, peserta yang telah selesai, serta aktivitas
                terbaru sistem.

            </p>

        </div>

    </div>

</div>

<!-- ===================================== -->
<!-- CHART.JS -->
<!-- ===================================== -->

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

const ctx = document.getElementById("dashboardChart");

new Chart(ctx,{

    type:"bar",

    data:{

        labels:[

            "Guru",

            "Siswa",

            "Kelas",

            "Mapel",

            "Ujian",

            "Bank Soal"

        ],

        datasets:[{

            label:"Jumlah Data",

            data:[

                <%= statistik.guru %>,

                <%= statistik.siswa %>,

                <%= statistik.kelas %>,

                <%= statistik.mapel %>,

                <%= statistik.ujian %>,

                <%= statistik.bankSoal %>

            ],

            borderWidth:1

        }]

    },

    options:{

    responsive:true,

    maintainAspectRatio:false,

    animation:false,

    scales:{

        y:{

            beginAtZero:true,

            ticks:{

                precision:0

            }

        }

    },

    plugins:{

        legend:{

            display:false

        }

    }

}

});

</script>

<%- include("../partials/footer") %>