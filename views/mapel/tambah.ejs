<%- include("../partials/header",{title:"Tambah Mata Pelajaran"}) %>

<%- include("../partials/sidebar") %>

<div class="main">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2>Tambah Mata Pelajaran</h2>

            <small class="text-muted">

                Tambahkan data mata pelajaran baru

            </small>

        </div>

    </div>

    <div class="card shadow-sm">

        <div class="card-body">

            <form action="/mapel/simpan" method="POST">

                <div class="row">

                    <div class="col-md-6 mb-3">

                        <label class="form-label">

                            Kode Mata Pelajaran

                        </label>

                        <input
                            type="text"
                            name="kode_mapel"
                            class="form-control"
                            placeholder="Contoh : MTK001"
                            required>

                    </div>

                    <div class="col-md-6 mb-3">

                        <label class="form-label">

                            Nama Mata Pelajaran

                        </label>

                        <input
                            type="text"
                            name="nama_mapel"
                            class="form-control"
                            placeholder="Contoh : Matematika"
                            required>

                    </div>

                    <div class="col-md-6 mb-3">

                        <label class="form-label">

                            KKM

                        </label>

                        <input
                            type="number"
                            name="kkm"
                            class="form-control"
                            value="75"
                            min="0"
                            max="100"
                            required>

                    </div>

                    <div class="col-md-6 mb-3">

                        <label class="form-label">

                            Status

                        </label>

                        <select
                            name="status"
                            class="form-select"
                            required>

                            <option value="1">Aktif</option>
                            <option value="0">Nonaktif</option>

                        </select>

                    </div>

                </div>

                <hr>

                <button
                    type="submit"
                    class="btn btn-primary">

                    <i class="bi bi-save"></i>

                    Simpan

                </button>

                <a
                    href="/mapel"
                    class="btn btn-secondary">

                    <i class="bi bi-arrow-left"></i>

                    Kembali

                </a>

            </form>

        </div>

    </div>

</div>

<%- include("../partials/footer") %>