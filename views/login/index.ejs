<!DOCTYPE html>
<html lang="id">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>SIM-UJIAN SEKOLAH</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>

        body{
            background:#0d6efd;
        }

        .login-box{
            width:420px;
            margin:auto;
            margin-top:90px;
        }

        .card{
            border:none;
            border-radius:15px;
        }

        .logo{
            font-size:38px;
            font-weight:bold;
            color:#0d6efd;
        }

    </style>

</head>

<body>

<div class="login-box">

    <div class="card shadow">

        <div class="card-body p-5">

            <div class="text-center mb-4">

                <div class="logo">
                    SIM-UJIAN
                </div>

                <p class="text-muted">
                    Computer Based Test
                </p>

            </div>

            <form action="/login" method="POST">

                <div class="mb-3">

                    <label class="form-label">
                        Username
                    </label>

                    <input
                        type="text"
                        name="username"
                        class="form-control"
                        placeholder="Masukkan Username"
                        required>

                </div>

                <div class="mb-3">

                    <label class="form-label">
                        Password
                    </label>

                    <input
                        type="password"
                        name="password"
                        class="form-control"
                        placeholder="Masukkan Password"
                        required>

                </div>

                <button
                    type="submit"
                    class="btn btn-primary w-100">

                    LOGIN

                </button>

            </form>

        </div>

    </div>

</div>

</body>

</html>