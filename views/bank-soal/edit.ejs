<%- include("../partials/header",{title:"Edit Soal"}) %>

<%- include("../partials/sidebar") %>

<div class="main">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2>Edit Soal</h2>

            <small class="text-muted">

                Ubah data soal

            </small>

        </div>

    </div>

    <div class="card shadow-sm">

        <div class="card-body">

            <form
    action="/bank-soal/update/<%= soal.id %>"
    method="POST"
    enctype="multipart/form-data">

                <div class="row">

                    <div class="col-md-6 mb-3">

                        <label class="form-label">Mata Pelajaran</label>

<% if(role==="admin"){ %>
<select name="mapel_id" class="form-select" required>
<% mapel.forEach(item=>{ %>
<option value="<%= item.id %>" <%= item.id==soal.mapel_id ? "selected" : "" %>><%= item.nama_mapel %></option>
<% }) %>
</select>
<% }else{ %>
<input type="text" class="form-control" value="<%= mapel[0].nama_mapel %>" readonly>
<input type="hidden" name="mapel_id" value="<%= mapel[0].id %>">
<% } %>

                    </div>

                    <div class="col-md-6 mb-3">

                        <label class="form-label">Guru</label>

<% if(role==="admin"){ %>
<select name="guru_id" class="form-select" required>
<% guru.forEach(item=>{ %>
<option value="<%= item.id %>" <%= item.id==soal.guru_id ? "selected" : "" %>><%= item.nama %></option>
<% }) %>
</select>
<% }else{ %>
<input type="text" class="form-control" value="<%= guru[0].nama %>" readonly>
<input type="hidden" name="guru_id" value="<%= guru[0].id %>">
<% } %>

                    </div>

                    <div class="col-md-4 mb-3">

                        <label>Jenis Soal</label>

                        <select name="jenis" class="form-select">

                            <option value="PG" <%= soal.jenis=="PG" ? "selected":"" %>>Pilihan Ganda</option>

                            <option value="Essay" <%= soal.jenis=="Essay" ? "selected":"" %>>Essay</option>

                            <option value="Benar Salah" <%= soal.jenis=="Benar Salah" ? "selected":"" %>>Benar / Salah</option>

                        </select>

                    </div>

                    <div class="col-md-4 mb-3">

                        <label>Bobot</label>

                        <input
                            type="number"
                            name="bobot"
                            class="form-control"
                            value="<%= soal.bobot %>">

                    </div>

                    <div class="col-md-4 mb-3">

                        <label>Status</label>

                        <select
                            name="status"
                            class="form-select">

                            <option value="1" <%= soal.status==1 ? "selected":"" %>>

                                Aktif

                            </option>

                            <option value="0" <%= soal.status==0 ? "selected":"" %>>

                                Nonaktif

                            </option>

                        </select>

                    </div>

                    <div class="col-md-12 mb-3">

                        <label>Pertanyaan</label>

                        <textarea
                            name="pertanyaan"
                            rows="5"
                            class="form-control"><%= soal.pertanyaan %></textarea>

                    </div>

                    <div class="col-md-6 mb-3">

                        <label>Pilihan A</label>

                        <input
                            type="text"
                            name="pilihan_a"
                            class="form-control"
                            value="<%= soal.pilihan_a %>">

                    </div>

                    <div class="col-md-6 mb-3">

                        <label>Pilihan B</label>

                        <input
                            type="text"
                            name="pilihan_b"
                            class="form-control"
                            value="<%= soal.pilihan_b %>">

                    </div>

                    <div class="col-md-6 mb-3">

                        <label>Pilihan C</label>

                        <input
                            type="text"
                            name="pilihan_c"
                            class="form-control"
                            value="<%= soal.pilihan_c %>">

                    </div>

                    <div class="col-md-6 mb-3">

                        <label>Pilihan D</label>

                        <input
                            type="text"
                            name="pilihan_d"
                            class="form-control"
                            value="<%= soal.pilihan_d %>">

                    </div>

                    <div class="col-md-6 mb-3">

                        <label>Pilihan E</label>

                        <input
                            type="text"
                            name="pilihan_e"
                            class="form-control"
                            value="<%= soal.pilihan_e %>">

                    </div>

                    <div class="col-md-6 mb-3">

                        <label>Jawaban Benar</label>

                        <select
                            name="jawaban"
                            class="form-select">

                            <option value="A" <%= soal.jawaban=="A"?"selected":"" %>>A</option>
                            <option value="B" <%= soal.jawaban=="B"?"selected":"" %>>B</option>
                            <option value="C" <%= soal.jawaban=="C"?"selected":"" %>>C</option>
                            <option value="D" <%= soal.jawaban=="D"?"selected":"" %>>D</option>
                            <option value="E" <%= soal.jawaban=="E"?"selected":"" %>>E</option>

                        </select>

                    </div>

                </div>

<!-- ============================================== -->
<!-- MULTIMEDIA SOAL -->
<!-- ============================================== -->

<div class="row">

    <!-- ================================= -->
    <!-- GAMBAR -->
    <!-- ================================= -->

    <div class="col-md-12 mb-4">

        <label class="form-label">

            Gambar Saat Ini

        </label>

        <% if(soal.gambar){ %>

            <div class="card mb-3">

                <div class="card-body text-center">

                    <img
                        src="/uploads/gambar/soal/<%= soal.gambar %>"
                        class="img-fluid rounded border"
                        style="max-height:300px;">

                    <div class="mt-2">

                        <small class="text-muted">

                            <%= soal.gambar %>

                        </small>

                    </div>

                </div>

            </div>

        <% }else{ %>

            <div class="alert alert-secondary">

                Tidak ada gambar.

            </div>

        <% } %>

        <label class="form-label">

            Ganti Gambar

        </label>

        <input
            type="file"
            id="gambarSoal"
            name="gambar"
            class="form-control"
            accept=".jpg,.jpeg,.png,.webp,.gif">

        <div class="mt-3">

            <img
                id="previewGambar"
                class="img-fluid rounded border"
                style="display:none;max-height:250px;">

        </div>

    </div>

    <!-- ================================= -->
    <!-- AUDIO -->
    <!-- ================================= -->

    <div class="col-md-12 mb-4">

        <label class="form-label">

            Audio Saat Ini

        </label>

        <% if(soal.audio){ %>

            <audio controls style="width:100%;">

                <source
                    src="/uploads/audio/soal/<%= soal.audio %>">

            </audio>

            <div class="mt-2">

                <small class="text-muted">

                    <%= soal.audio %>

                </small>

            </div>

        <% }else{ %>

            <div class="alert alert-secondary">

                Tidak ada audio.

            </div>

        <% } %>

        <label class="form-label mt-3">

            Ganti Audio

        </label>

        <input
            type="file"
            id="audioSoal"
            name="audio"
            class="form-control"
            accept=".mp3,.wav,.ogg,.m4a">

        <div class="mt-3">

            <audio
                id="previewAudio"
                controls
                style="display:none;width:100%;">

            </audio>

        </div>

    </div>

    <!-- ================================= -->
    <!-- VIDEO -->
    <!-- ================================= -->

    <div class="col-md-12 mb-4">

        <label class="form-label">

            Video Saat Ini

        </label>

        <% if(soal.video){ %>

            <video
                controls
                style="width:100%;max-height:420px;">

                <source
                    src="/uploads/video/soal/<%= soal.video %>">

            </video>

            <div class="mt-2">

                <small class="text-muted">

                    <%= soal.video %>

                </small>

            </div>

        <% }else{ %>

            <div class="alert alert-secondary">

                Tidak ada video.

            </div>

        <% } %>

        <label class="form-label mt-3">

            Ganti Video

        </label>

        <input
            type="file"
            id="videoSoal"
            name="video"
            class="form-control"
            accept=".mp4,.webm,.mov,.avi,.mkv">

        <div class="mt-3">

            <video
                id="previewVideo"
                controls
                style="display:none;width:100%;max-height:350px;">

            </video>

        </div>

    </div>

</div>

                <hr>

                <button type="submit" class="btn btn-primary">

                    <i class="bi bi-save"></i>

                    Update Soal

                </button>

                <a href="/bank-soal" class="btn btn-secondary">

                    Kembali

                </a>

            </form>

        </div>

    </div>

</div>

<!-- Script untuk menampilkan preview gambar yang dipilih -->
<script>
// ===========================
// PREVIEW GAMBAR
// ===========================

const gambarInput=document.getElementById("gambarSoal");
const gambarPreview=document.getElementById("previewGambar");

gambarInput.addEventListener("change",function(){

    const file=this.files[0];

    if(!file){

        gambarPreview.style.display="none";

        return;

    }

    gambarPreview.src=URL.createObjectURL(file);

    gambarPreview.style.display="block";

});

// ===========================
// PREVIEW AUDIO
// ===========================

const audioInput=document.getElementById("audioSoal");
const audioPreview=document.getElementById("previewAudio");

audioInput.addEventListener("change",function(){

    const file=this.files[0];

    if(!file){

        audioPreview.style.display="none";

        return;

    }

    audioPreview.src=URL.createObjectURL(file);

    audioPreview.style.display="block";

});

// ===========================
// PREVIEW VIDEO
// ===========================

const videoInput=document.getElementById("videoSoal");
const videoPreview=document.getElementById("previewVideo");

videoInput.addEventListener("change",function(){

    const file=this.files[0];

    if(!file){

        videoPreview.style.display="none";

        return;

    }

    videoPreview.src=URL.createObjectURL(file);

    videoPreview.style.display="block";

});

</script>

<%- include("../partials/footer") %>