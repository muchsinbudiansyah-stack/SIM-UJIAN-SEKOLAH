<!DOCTYPE html>
<html lang="id">

<head>

<meta charset="UTF-8">

<meta name="viewport"
content="width=device-width, initial-scale=1">

<title>

Detail Hasil Ujian

</title>

<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
rel="stylesheet">

<style>

body{

    background:#f5f7fb;

}

.card{

    border:none;

    border-radius:12px;

}

.status-benar{

    color:#198754;

    font-weight:bold;

}

.status-salah{

    color:#dc3545;

    font-weight:bold;

}

</style>

</head>

<body>

<div class="container mt-4">

<div class="card shadow">

<div class="card-header bg-primary text-white">

<h3 class="mb-0">

Detail Hasil Ujian

</h3>

</div>

<div class="card-body">

<div class="row">

<div class="col-md-6">

<table class="table table-borderless">

<tr>

<td width="180"><b>ID Hasil</b></td>

<td>: <%= hasil.id %></td>

</tr>

<tr>

<td><b>Nilai</b></td>

<td>

:

<span class="badge bg-success">

<%= hasil.nilai %>

</span>

</td>

</tr>

<tr>

<td><b>Benar</b></td>

<td>

:

<%= hasil.benar %>

</td>

</tr>

<tr>

<td><b>Salah</b></td>

<td>

:

<%= hasil.salah %>

</td>

</tr>

<tr>

<td><b>Kosong</b></td>

<td>

:

<%= hasil.kosong %>

</td>

</tr>

</table>

</div>

<div class="col-md-6">

<table class="table table-borderless">

<tr>

<td width="180">

<b>Status</b>

</td>

<td>

:

<span class="badge bg-primary">

<%= hasil.status %>

</span>

</td>

</tr>

<tr>

<td>

<b>Waktu Selesai</b>

</td>

<td>

:

<%= hasil.waktu_selesai %>

</td>

</tr>

</table>

</div>

</div>

<hr>

<h4 class="mb-4">

Daftar Jawaban Siswa

</h4>

<% if(jawaban.length===0){ %>

<div class="alert alert-warning">

Belum ada data jawaban.

</div>

<% } %>

<% jawaban.forEach(function(item,index){ %>

<div class="card mb-4 border">

<div class="card-header bg-light">

<b>

Soal <%= index+1 %>

</b>

</div>

<div class="card-body">

<div class="mb-3">

<h5 class="fw-bold">

Soal Nomor <%= index+1 %>

</h5>

<div class="mt-3">

<%- item.pertanyaan %>

</div>

<% if(item.gambar){ %>

<div class="mt-3">

<img

src="/uploads/<%= item.gambar %>"

class="img-fluid rounded border"

style="max-width:500px;">

</div>

<% } %>

<% if(item.audio){ %>

<div class="mt-3">

<audio controls class="w-100">

<source

src="/uploads/<%= item.audio %>">

</audio>

</div>

<% } %>

<% if(item.video){ %>

<div class="mt-3">

<video

controls

class="w-100 rounded"

style="max-width:700px;">

<source

src="/uploads/<%= item.video %>">

</video>

</div>

<% } %>

</div>

<hr>

<table class="table table-bordered">

<tr>

<th width="150">

Jawaban Siswa

</th>

<td>

<b>

<%= item.jawaban %>

</b>

</td>

</tr>

<tr>

<th>

Kunci Jawaban

</th>

<td>

<b>

<%= item.kunci %>

</b>

</td>

</tr>

<tr>

<th>Status</th>

<td>

<% if(item.jawaban==item.kunci){ %>

<div class="alert alert-success mb-0">

<h5 class="mb-1">

✅ Jawaban Benar

</h5>

Jawaban siswa sama dengan kunci jawaban.

</div>

<% }else{ %>

<div class="alert alert-danger mb-0">

<h5 class="mb-1">

❌ Jawaban Salah

</h5>

Jawaban siswa:

<b><%= item.jawaban %></b>

<br>

Kunci jawaban:

<b><%= item.kunci %></b>

</div>

<% } %>

</td>

</tr>

</table>

<h6>

Pilihan Jawaban

<div class="mt-4">

<h6>Pilihan Jawaban</h6>

<%
const opsi = {

A:item.pilihan_a,

B:item.pilihan_b,

C:item.pilihan_c,

D:item.pilihan_d,

E:item.pilihan_e

};

%>

<% Object.keys(opsi).forEach(function(huruf){ %>

<div

class="border rounded p-3 mb-2

<%= item.jawaban==huruf
? 'border-danger bg-danger-subtle'
: ''

%>

<%= item.kunci==huruf
? 'border-success bg-success-subtle'
: ''

%>">

<b>

<%= huruf %>.

</b>

<%= opsi[huruf] %>

<% if(item.kunci==huruf){ %>

<span class="badge bg-success ms-2">

✔ Kunci

</span>

<% } %>

<% if(item.jawaban==huruf){ %>

<span class="badge bg-danger ms-2">

Jawaban Siswa

</span>

<% } %>

</div>

<% }) %>

</div>

</div>

</div>

<% }) %>

<hr>

<div class="d-flex justify-content-between">

<a
href="/hasil"
class="btn btn-secondary">

← Kembali

</a>

<div>

<button
class="btn btn-success"
onclick="window.print()">

🖨 Cetak

</button>

</div>

</div>

</div>

</div>

</div>

</body>

</html>