<%- include("../partials/header",{title:"Tambah Guru"}) %>

<%- include("../partials/sidebar") %>

<div class="main">

<h2 class="mb-4">

Tambah Guru

</h2>

<div class="card shadow">

<div class="card-body">

<form action="/guru/simpan" method="POST">

<div class="row">

<div class="col-md-6 mb-3">

<label>NIP</label>

<input
type="text"
name="nip"
class="form-control"
required>

</div>

<div class="col-md-6 mb-3">

<label>Nama Guru</label>

<input
type="text"
name="nama"
class="form-control"
required>

</div>

<div class="col-md-6 mb-3">

<label>Email</label>

<input
type="email"
name="email"
class="form-control">

</div>

<div class="col-md-6 mb-3">

<label>No HP</label>

<input
type="text"
name="hp"
class="form-control">

</div>

<div class="col-md-6 mb-3">

<label>Mata Pelajaran</label>

<input
type="text"
name="mapel"
class="form-control">

</div>

</div>

<button class="btn btn-success">

Simpan

</button>

<a
href="/guru"
class="btn btn-secondary">

Kembali

</a>

</form>

</div>

</div>

</div>

<%- include("../partials/footer") %>