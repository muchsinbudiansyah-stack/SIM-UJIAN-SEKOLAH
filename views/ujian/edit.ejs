<%- include("../partials/header",{title:"Edit Ujian"}) %>

<%- include("../partials/sidebar") %>

<div class="main">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2>Edit Ujian</h2>

            <small class="text-muted">

                Ubah konfigurasi ujian

            </small>

        </div>

    </div>

    <div class="card shadow-sm">

        <div class="card-body">

            <form action="/ujian/update/<%= ujian.id %>" method="POST">

                <div class="row">

                    <div class="col-md-6 mb-3">

                        <label>Nama Ujian</label>

                        <input
                            type="text"
                            name="nama_ujian"
                            class="form-control"
                            value="<%= ujian.nama_ujian %>"
                            required>

                    </div>

                    <div class="col-md-6 mb-3">

                        <label>Mata Pelajaran</label>

                        <select
                            name="mapel_id"
                            class="form-select"
                            required>

                            <% mapel.forEach(item=>{ %>

                                <option
                                    value="<%= item.id %>"
                                    <%= item.id==ujian.mapel_id ? "selected" : "" %>>

                                    <%= item.nama_mapel %>

                                </option>

                            <% }) %>

                        </select>

                    </div>

                    <div class="col-md-6 mb-3">

                        <label>Kelas</label>

                        <select
                            name="kelas_id"
                            class="form-select"
                            required>

                            <% kelas.forEach(item=>{ %>

                                <option
                                    value="<%= item.id %>"
                                    <%= item.id==ujian.kelas_id ? "selected" : "" %>>

                                    <%= item.nama %>

                                </option>

                            <% }) %>

                        </select>

                    </div>

                    <div class="col-md-6 mb-3">

                        <label>Guru</label>

                        <select
                            name="guru_id"
                            class="form-select"
                            required>

                            <% guru.forEach(item=>{ %>

                                <option
                                    value="<%= item.id %>"
                                    <%= item.id==ujian.guru_id ? "selected" : "" %>>

                                    <%= item.nama %>

                                </option>

                            <% }) %>

                        </select>

                    </div>

                    <div class="col-md-4 mb-3">

                        <label>Tanggal</label>

                        <input
                            type="date"
                            name="tanggal"
                            class="form-control"
                            value="<%= ujian.tanggal %>"
                            required>

                    </div>

                    <div class="col-md-4 mb-3">

                        <label>Jam Mulai</label>

                        <input
                            type="time"
                            name="jam_mulai"
                            class="form-control"
                            value="<%= ujian.jam_mulai %>"
                            required>

                    </div>

                    <div class="col-md-4 mb-3">

                        <label>Jam Selesai</label>

                        <input
                            type="time"
                            name="jam_selesai"
                            class="form-control"
                            value="<%= ujian.jam_selesai %>"
                            required>

                    </div>

                    <div class="col-md-4 mb-3">

                        <label>Durasi (Menit)</label>

                        <input
                            type="number"
                            name="durasi"
                            class="form-control"
                            value="<%= ujian.durasi %>"
                            required>

                    </div>

                    <div class="col-md-4 mb-3">

                        <label>Jumlah Soal</label>

                        <input
                            type="number"
                            name="jumlah_soal"
                            class="form-control"
                            value="<%= ujian.jumlah_soal %>"
                            required>

                    </div>

                    <div class="col-md-4 mb-3">

                        <label>Token</label>

                        <input
                            type="text"
                            name="token"
                            class="form-control"
                            value="<%= ujian.token %>">

                    </div>

                    <div class="col-md-6 mb-3">

                        <div class="form-check">

                            <input
                                class="form-check-input"
                                type="checkbox"
                                name="acak_soal"
                                value="1"
                                <%= ujian.acak_soal==1 ? "checked" : "" %>>

                            <label class="form-check-label">

                                Acak Soal

                            </label>

                        </div>

                    </div>

                    <div class="col-md-6 mb-3">

                        <div class="form-check">

                            <input
                                class="form-check-input"
                                type="checkbox"
                                name="acak_jawaban"
                                value="1"
                                <%= ujian.acak_jawaban==1 ? "checked" : "" %>>

                            <label class="form-check-label">

                                Acak Jawaban

                            </label>

                        </div>

                    </div>

                </div>

                <hr>

                <button
                    type="submit"
                    class="btn btn-primary">

                    Update Ujian

                </button>

                <a
                    href="/ujian"
                    class="btn btn-secondary">

                    Kembali

                </a>

            </form>

        </div>

    </div>

</div>

<%- include("../partials/footer") %>