<!DOCTYPE html>
<html lang="id">

<head>

    <meta charset="UTF-8">

    <title>Hasil Ujian</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet">

</head>

<body class="bg-light">

<div class="container mt-5">

    <div class="card shadow">

        <div class="card-body">

            <h2 class="text-center mb-4">
                Ujian Selesai
            </h2>

            <!-- ========================= -->
            <!-- INFORMASI UJIAN -->
            <!-- ========================= -->

            <table class="table table-borderless w-50 mx-auto">

                <tr>
                    <td width="40%"><strong>Nama Ujian</strong></td>
                    <td>: <%= ujian.nama_ujian %></td>
                </tr>

                <tr>
                    <td><strong>Mata Pelajaran</strong></td>
                    <td>: <%= ujian.nama_mapel %></td>
                </tr>

                <tr>
                    <td><strong>Peserta</strong></td>
                    <td>: <%= siswa.nama %></td>
                </tr>

            </table>

            <hr>

            <!-- ========================= -->
            <!-- HASIL PG -->
            <!-- ========================= -->

            <h4 class="text-center text-primary mb-3">
                Hasil Pilihan Ganda
            </h4>

            <p class="text-center">
                Total Soal PG :
                <strong><%= jumlahPG %></strong>
            </p>

            <div class="row text-center">

                <div class="col">

                    <h5>Benar</h5>

                    <h2 class="text-success">

                        <%= benar %>

                    </h2>

                </div>

                <div class="col">

                    <h5>Salah</h5>

                    <h2 class="text-danger">

                        <%= salah %>

                    </h2>

                </div>

                <div class="col">

                    <h5>Kosong</h5>

                    <h2 class="text-warning">

                        <%= kosong %>

                    </h2>

                </div>

            </div>

            <hr>

            <h3 class="text-center">
                Nilai Pilihan Ganda
            </h3>

            <h1 class="text-center text-primary">

                <%= nilaiPG %>

            </h1>

            <!-- ========================= -->
            <!-- HASIL ESSAY -->
            <!-- ========================= -->

            <% if (adaEssay) { %>

            <hr>

            <div class="alert alert-warning">

                <h5 class="text-center mb-3">
                    Hasil Essay
                </h5>

                <p>
                    Jumlah Soal :
                    <strong><%= jumlahEssay %></strong>
                </p>

                <p class="mb-0">
                    Status :
                    <strong><%= statusEssay %></strong>
                </p>

            </div>

            <hr>

            <h3 class="text-center text-secondary">
                Nilai Akhir
            </h3>

            <h2 class="text-center text-muted">
                Belum tersedia
            </h2>

            <% } %>

            <div class="text-center mt-4">

                <a href="/peserta/dashboard"
                   class="btn btn-primary">

                    Kembali ke Dashboard

                </a>

            </div>

        </div>

    </div>

</div>

</body>

</html>