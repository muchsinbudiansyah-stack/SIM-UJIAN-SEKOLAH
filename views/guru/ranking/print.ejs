<!DOCTYPE html>

<html>

<head>

<meta charset="UTF-8">

<title>

Ranking Nilai

</title>

<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
rel="stylesheet">

</head>

<body style="margin:40px;">

<h2 class="text-center">

RANKING NILAI SISWA

</h2>

<hr>

<table class="table table-bordered">

<thead>

<tr>

<th>Rank</th>

<th>Nama</th>

<th>NISN</th>

<th>Kelas</th>

<th>Nilai</th>

</tr>

</thead>

<tbody>

<%

let rank=1;

ranking.forEach(item=>{

%>

<tr>

<td>

<%= rank++ %>

</td>

<td>

<%= item.nama %>

</td>

<td>

<%= item.nisn %>

</td>

<td>

<%= item.kelas %>

</td>

<td>

<%= item.nilai %>

</td>

</tr>

<%

})

%>

</tbody>

</table>

</body>

</html>