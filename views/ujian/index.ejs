<%- include("../partials/header",{title:"Data Ujian"}) %>

<%- include("../partials/sidebar") %>

<div class="main">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2 class="mb-1">

                Data Ujian

            </h2>

            <small class="text-muted">

                Manajemen Jadwal Ujian CBT

            </small>

        </div>

        <a
            href="/ujian/tambah"
            class="btn btn-primary">

            <i class="bi bi-plus-circle"></i>

            Buat Ujian

        </a>

    </div>

    <% if(role==="guru"){ %>

        <div class="card shadow-sm mb-3">

            <div class="card-body">

                <form
                    method="GET"
                    action="/ujian">

                    <div class="row align-items-end">

                        <div class="col-md-5">

                            <label class="form-label">

                                Filter Mata Pelajaran

                            </label>

                            <select

                                name="mapel"

                                class="form-select"

                                onchange="this.form.submit()"

                            >

                                <% mapel.forEach(function(item){ %>

                                    <option

                                        value="<%= item.id %>"

                                        <%= String(selectedMapel)==String(item.id) ? "selected" : "" %>

                                    >

                                        <%= item.nama_mapel %>

                                    </option>

                                <% }) %>

                            </select>

                        </div>

                    </div>

                </form>

            </div>

        </div>

    <% } %>

    <div class="card shadow-sm">

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-bordered table-hover align-middle">

                    <thead class="table-primary">

                        <tr>

                            <th width="60">

                                No

                            </th>

                            <th>

                                Nama Ujian

                            </th>

                            <th>

                                Mata Pelajaran

                            </th>

                            <th>

                                Kelas

                            </th>

                            <th>

                                Guru

                            </th>

                            <th width="90">

                                Durasi

                            </th>

                            <th width="100">

                                Status

                            </th>

                            <th width="110">

                                Peserta

                            </th>

                            <th width="220">

                                Aksi

                            </th>

                        </tr>

                    </thead>

                    <tbody>

                        <% if(ujian.length===0){ %>

                            <tr>

                                <td
                                    colspan="9"
                                    class="text-center text-muted">

                                    Belum ada data ujian.

                                </td>

                            </tr>

                        <% } %>

                        <% ujian.forEach((item,index)=>{ %>

                            <tr>

                                <td>

                                    <%= index+1 %>

                                </td>

                                <td>

                                    <strong>

                                        <%= item.nama_ujian %>

                                    </strong>

                                </td>

                                <td>

                                    <span class="badge bg-primary">

                                        <%= item.nama_mapel %>

                                    </span>

                                </td>

                                <td>

                                    <%= item.nama_kelas %>

                                </td>

                                <td>

                                    <%= item.nama_guru %>

                                </td>

                                <td>

                                    <%= item.durasi %> Menit

                                </td>

                                <td>

                                    <% if(item.status==1){ %>

                                        <span class="badge bg-success">

                                            Aktif

                                        </span>

                                    <% }else{ %>

                                        <span class="badge bg-secondary">

                                            Nonaktif

                                        </span>

                                    <% } %>

                                </td>

                                <td>

                                    <a

                                        href="/ujian/peserta/<%= item.id %>"

                                        class="btn btn-info btn-sm">

                                        <i class="bi bi-people"></i>

                                        Peserta

                                    </a>

                                </td>

                                <td>

                                    <a

                                        href="/ujian/edit/<%= item.id %>"

                                        class="btn btn-warning btn-sm">

                                        <i class="bi bi-pencil-square"></i>

                                        Edit

                                    </a>

                                    <a

                                        href="/ujian/hapus/<%= item.id %>"

                                        class="btn btn-danger btn-sm"

                                        onclick="return confirm('Yakin ingin menghapus ujian ini?')">

                                        <i class="bi bi-trash"></i>

                                        Hapus

                                    </a>

                                </td>

                            </tr>

                        <% }) %>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

<%- include("../partials/footer") %>